<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1a1a1a"
    android:padding="4dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:id="@+id/key_q" android:text="q" style="@style/Key"/>
        <TextView android:id="@+id/key_w" android:text="w" style="@style/Key"/>
        <TextView android:id="@+id/key_e" android:text="e" style="@style/Key"/>
        <TextView android:id="@+id/key_r" android:text="r" style="@style/Key"/>
        <TextView android:id="@+id/key_t" android:text="t" style="@style/Key"/>
        <TextView android:id="@+id/key_y" android:text="y" style="@style/Key"/>
        <TextView android:id="@+id/key_u" android:text="u" style="@style/Key"/>
        <TextView android:id="@+id/key_i" android:text="i" style="@style/Key"/>
        <TextView android:id="@+id/key_o" android:text="o" style="@style/Key"/>
        <TextView android:id="@+id/key_p" android:text="p" style="@style/Key"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_horizontal">
        <TextView android:id="@+id/key_a" android:text="a" style="@style/Key"/>
        <TextView android:id="@+id/key_s" android:text="s" style="@style/Key"/>
        <TextView android:id="@+id/key_d" android:text="d" style="@style/Key"/>
        <TextView android:id="@+id/key_f" android:text="f" style="@style/Key"/>
        <TextView android:id="@+id/key_g" android:text="g" style="@style/Key"/>
        <TextView android:id="@+id/key_h" android:text="h" style="@style/Key"/>
        <TextView android:id="@+id/key_j" android:text="j" style="@style/Key"/>
        <TextView android:id="@+id/key_k" android:text="k" style="@style/Key"/>
        <TextView android:id="@+id/key_l" android:text="l" style="@style/Key"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:id="@+id/key_shift" android:text="shift" style="@style/Key"/>
        <TextView android:id="@+id/key_z" android:text="z" style="@style/Key"/>
        <TextView android:id="@+id/key_x" android:text="x" style="@style/Key"/>
        <TextView android:id="@+id/key_c" android:text="c" style="@style/Key"/>
        <TextView android:id="@+id/key_v" android:text="v" style="@style/Key"/>
        <TextView android:id="@+id/key_b" android:text="b" style="@style/Key"/>
        <TextView android:id="@+id/key_n" android:text="n" style="@style/Key"/>
        <TextView android:id="@+id/key_m" android:text="m" style="@style/Key"/>
        <TextView android:id="@+id/key_del" android:text="del" style="@style/Key"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:id="@+id/key_num" android:text="123" style="@style/Key"/>
        <TextView android:id="@+id/key_space" android:text=" " style="@style/KeySpace"/>
        <TextView android:id="@+id/key_enter" android:text="enter" style="@style/Key"/>
    </LinearLayout>
</LinearLayout>
